# Скопируйте в .env и заполните.

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Подключение к PostgreSQL (совпадает с docker-compose.yml)
DATABASE_URL=postgresql://wegrow:wegrow@localhost:5432/wegrow

# Telegram ID администраторов P&C через запятую
ADMIN_IDS=111111111,222222222

# Таймзона марафона
TZ=Europe/Moscow

# Премиум-эмодзи (нужен Telegram Premium у владельца бота + ID в bot/emoji_ids.json).
# Пока false — везде обычные эмодзи. См. docs/premium-emoji.md.
PREMIUM_EMOJI=false

# URL мини-аппа (веб-сервис wegrow-webapp). Задаёт постоянную кнопку меню бота.
# Напр. https://wegrow-webapp.onrender.com. Пусто — кнопка не ставится.
# ВАЖНО: без этого адреса кнопки «Мой прогресс/Лидерборд» открывают приложение
# без initData и оно пишет «открой из бота». Адрес также можно задать в
# админ-панели (📢 не требует редеплоя) — он переопределяет эту переменную.
WEBAPP_URL=

# Даты марафона (ISO). До старта бот не принимает шаги, а «Прогресс» заблюрен.
MARATHON_START=2026-07-17
MARATHON_END=2026-08-07

# Каналы для заявок на вступление и проверки результатов настраиваются
# из админ-панели бота (раздел «📢 Каналы») — переменные окружения не нужны.
