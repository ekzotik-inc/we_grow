# Скопируйте в .env и заполните.

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Подключение к PostgreSQL (совпадает с docker-compose.yml)
DATABASE_URL=postgresql://wegrow:wegrow@localhost:5432/wegrow

# Telegram ID администраторов P&C через запятую
ADMIN_IDS=111111111,222222222

# Таймзона марафона
TZ=Europe/Moscow

# Премиум-эмодзи (нужен Telegram Premium у владельца бота + ID в bot/emoji_ids.json).
# Пока false — везде обычные эмодзи. См. docs/premium-emoji.md.
PREMIUM_EMOJI=false
